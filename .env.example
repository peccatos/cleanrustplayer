DATABASE_URL=postgres://replaycore:replaycore@127.0.0.1:5432/replaycore
REPLAYCORE_DATABASE_URL=postgres://replaycore:replaycore@127.0.0.1:5432/replaycore
REPLAYCORE_DATABASE_CONNECT_TIMEOUT_MS=1000
REPLAYCORE_TOKEN_ENCRYPTION_KEY=base64-encoded-32-byte-key
REPLAYCORE_LOCAL_MUSIC_ROOT=D:\music-library
# REPLAYCORE_LOCAL_MUSIC_ROOTS=D:\music-library;D:\archive\music
REPLAYCORE_HTTP_HOST=127.0.0.1
REPLAYCORE_HTTP_PORT=3001
REPLAYCORE_SQLITE_PATH=data\replaycore.sqlite3

# Used only by explicit `rust-player db ...` commands.
# Cloud mode accepts either a Google Drive folder ID or a shared folder URL.
# REPLAYCORE_GOOGLE_DRIVE_FOLDER_ID=https://drive.google.com/drive/folders/<folder-id>
# For public folders, add an API key so Drive accepts the caller.
# REPLAYCORE_GOOGLE_DRIVE_API_KEY=your_google_api_key
# For private folders, add a bearer access token instead.
# REPLAYCORE_GOOGLE_DRIVE_ACCESS_TOKEN=your_oauth_access_token
# For long-lived private access, add refresh token and OAuth client credentials.
# REPLAYCORE_GOOGLE_DRIVE_REFRESH_TOKEN=your_refresh_token
# REPLAYCORE_GOOGLE_DRIVE_CLIENT_ID=your_oauth_client_id
# REPLAYCORE_GOOGLE_DRIVE_CLIENT_SECRET=your_oauth_client_secret
